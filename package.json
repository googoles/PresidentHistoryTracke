{
  "name": "korea-promise-tracker",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/supabase-js": "^2.53.0",
    "chart.js": "^4.4.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.2.6",
    "firebase": "^10.7.1",
    "lucide-react": "^0.263.1",
    "mapbox-gl": "^3.13.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "^8.0.4",
    "web-vitals": "^3.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "dev:supabase": "react-scripts start",
    "build": "react-scripts build",
    "build:optimized": "react-scripts build && node deployment/build-optimization.js",
    "test": "react-scripts test",
    "test:supabase": "react-scripts test --env=jsdom",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:ci": "CI=true react-scripts test --coverage --watchAll=false",
    "analyze": "npx source-map-explorer 'build/static/js/*.js'",
    "deploy:aws": "npm run build:optimized && aws s3 sync build/ s3://korea-promise-tracker-prod --delete",
    "deploy:firebase": "npm run build && firebase deploy",
    "deploy:production": "npm run build:optimized",
    "db:backup": "echo 'Database backup command to be implemented'",
    "security:audit": "npm audit && eslint src/ --ext .js,.jsx --config .eslintrc.security.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.16",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^27.5.1",
    "postcss": "^8.4.32",
    "react-scripts": "^5.0.1",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.0"
  }
}
